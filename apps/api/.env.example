# =============================================================================
# DataPrismAI — API Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# Never commit .env to version control.
#
# SECTION 1 — Application
# -----------------------------------------------------------------------------
APP_NAME=DataPrismAI API

# SECTION 2 — LLM / Ollama
# -----------------------------------------------------------------------------
# Base URL for the Ollama runtime (local or Docker service)
OLLAMA_HOST=http://localhost:11434
# Model tag to use for chat generation
OLLAMA_MODEL=qwen2.5:7b

# SECTION 3 — Vanna SQL (NL-to-SQL via Vanna)
# Set USE_VANNA=true to route SQL generation through Vanna first.
# -----------------------------------------------------------------------------
USE_VANNA=false
VANNA_MODEL=qwen2.5:7b

# SECTION 4 — StarRocks (Analytical Query Engine)
# Credentials for the StarRocks allin1 container or remote cluster.
# -----------------------------------------------------------------------------
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_USER=root
STARROCKS_PASSWORD=
# The database/catalog that holds semantic_*, dp_*, raw_*, ddm_* tables.
STARROCKS_DATABASE=cc_analytics

# SECTION 5 — Postgres (Operational Store)
# Stores chat sessions, audit logs, and user metadata.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://dataprismai:dataprismai@localhost:5432/dataprismai

# SECTION 6 — CORS
# Comma-separated list of allowed frontend origins.
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# SECTION 7 — Superset (optional BI integration)
# -----------------------------------------------------------------------------
SUPERSET_URL=http://localhost:8088
